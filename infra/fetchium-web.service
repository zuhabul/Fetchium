[Unit]
Description=Fetchium Landing Page
After=network.target
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
Type=simple
User=echo
WorkingDirectory=/home/echo/projects/Fetchium/apps/web
Environment=PORT=3100
Environment=HOSTNAME=127.0.0.1
Environment=NODE_ENV=production
EnvironmentFile=/home/echo/.fetchium/env
ExecStart=/home/echo/.bun/bin/bun run start

TimeoutStopSec=15
KillMode=mixed
KillSignal=SIGTERM
Restart=always
RestartSec=5

MemoryMax=1G
MemorySwapMax=0
CPUQuota=50%
TasksMax=256

StandardOutput=journal
StandardError=journal
SyslogIdentifier=fetchium-web

NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/echo/projects/Fetchium/apps/web
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictRealtime=yes
LockPersonality=yes

[Install]
WantedBy=multi-user.target
