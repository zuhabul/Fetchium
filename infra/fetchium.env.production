# Fetchium production environment for server15 deployment.
# Used by: scripts/deploy.sh and infra/docker-compose.prod.yml
#
# Replace placeholder values before first deploy.

FETCHIUM_ADMIN_SECRET=replace-with-openssl-rand-hex-32

# Optional provider / backend integrations
TAVILY_API_KEY=
SERPER_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=
BRAVE_API_KEY=
GITHUB_TOKEN=
YOUTUBE_API_KEY=

# Logging
RUST_LOG=info
