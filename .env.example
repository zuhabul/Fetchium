# HyperSearchX — environment variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# ─── Required ────────────────────────────────────────────────────────────────

# Admin secret for POST/GET/DELETE /v1/keys endpoints.
# Generate: openssl rand -hex 32
HSX_ADMIN_SECRET=changeme-use-openssl-rand-hex-32

# ─── Optional search API keys (fallback to SearXNG if absent) ────────────────

# Brave Search API (https://api.search.brave.com) — better quality than SearXNG
BRAVE_API_KEY=

# GitHub personal access token — improves rate limits for /v1/social/hackernews
GITHUB_TOKEN=

# YouTube Data API v3 key (https://console.cloud.google.com)
YOUTUBE_API_KEY=

# ─── Server configuration ────────────────────────────────────────────────────

HSX_API_HOST=0.0.0.0
HSX_API_PORT=3000

# Path to data directory (auth.db, cache)
HSX_DATA_DIR=~/.hypersearchx

# Override SearXNG instance (default: http://localhost:4040)
# SEARXNG_URL=http://your-custom-searxng:8080

# ─── Tracing / logging ───────────────────────────────────────────────────────

# Options: error, warn, info, debug, trace
RUST_LOG=info
