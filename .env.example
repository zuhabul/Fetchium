# Fetchium — environment variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# ─── Required ────────────────────────────────────────────────────────────────

# Admin secret for POST/GET/DELETE /v1/keys endpoints.
# Generate: openssl rand -hex 32
***REMOVED***=changeme-use-openssl-rand-hex-32

# ─── Optional search API keys (fallback to SearXNG if absent) ────────────────

# Brave Search API (https://api.search.brave.com) — better quality than SearXNG
BRAVE_API_KEY=

# GitHub personal access token — improves rate limits for /v1/social/hackernews
GITHUB_TOKEN=

# YouTube Data API v3 key (https://console.cloud.google.com)
YOUTUBE_API_KEY=

# ─── Server configuration ────────────────────────────────────────────────────

FETCHIUM_API_HOST=0.0.0.0
FETCHIUM_API_PORT=3000

# Path to data directory (auth.db, cache)
FETCHIUM_DATA_DIR=~/.fetchium

# Override SearXNG instance (default: ***REMOVED***)
# SEARXNG_URL=http://your-custom-searxng:8080

# ─── Tracing / logging ───────────────────────────────────────────────────────

# Options: error, warn, info, debug, trace
RUST_LOG=info

# ─── Deployment paths ────────────────────────────────────────────────────────

# Production compose stack:
#   docker compose -f infra/docker-compose.prod.yml up -d --build
# MCP HTTP endpoint:
#   fetchium serve --mode mcp --transport http --port 3471
